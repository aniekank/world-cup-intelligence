# ─────────────────────────────────────────────────────────────
# World Cup Intelligence Platform — environment configuration
# ─────────────────────────────────────────────────────────────

# Data source:
#   seed         → deterministic simulation engine (default, fully offline)
#   statsbomb    → StatsBomb open data: free, REAL, full shot-level (historical WC).
#                  Run `npm run data:statsbomb` once to build the local cache.
#   footballdata → live FIFA World Cup 2026 (football-data.org). Scores/standings only.
#   apifootball  → live FIFA World Cup 2026 + xG (API-Football, ~$19/mo).
DATA_SOURCE=seed

# football-data.org free key (required when DATA_SOURCE=footballdata)
FOOTBALL_DATA_API_KEY=

# API-Football key (required when DATA_SOURCE=apifootball) — api-sports.io
API_FOOTBALL_KEY=

# Production database (only required when persisting to Postgres via Prisma)
DATABASE_URL="postgresql://user:password@localhost:5432/worldcup?schema=public"

# Public site URL (used for absolute OG/social image URLs)
NEXT_PUBLIC_SITE_URL=

# Optional: Anthropic API key. When present, the AI layer upgrades from the
# deterministic narrative engine to Claude-generated narratives.
# The app is fully functional WITHOUT this key.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# Cache TTLs (seconds) for the API edge cache
CACHE_TTL_LIVE=15
CACHE_TTL_STANDARD=300
CACHE_TTL_STATIC=86400

# Observability (optional)
OTEL_EXPORTER_OTLP_ENDPOINT=
SENTRY_DSN=
